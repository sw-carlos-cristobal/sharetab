{
  "name": "sharetab",
  "version": "0.8.0",
  "description": "Self-hosted, open-source Splitwise alternative with AI-powered receipt scanning",
  "author": "Carlos Cristobal",
  "license": "MIT",
  "homepage": "https://github.com/sw-carlos-cristobal/sharetab",
  "repository": {
    "type": "git",
    "url": "https://github.com/sw-carlos-cristobal/sharetab.git"
  },
  "keywords": [
    "self-hosted",
    "splitwise-alternative",
    "expense-tracker",
    "receipt-scanner",
    "ai",
    "nextjs",
    "docker",
    "unraid"
  ],
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:full": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "version:bump": "node scripts/version-bump.mjs",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:create": "npm run release:prepare --",
    "release:publish": "node scripts/release-publish.mjs",
    "pr:create": "node scripts/pr-create.mjs",
    "git:push-main": "node scripts/git-push-main.mjs",
    "push:main": "npm run git:push-main --",
    "db:seed": "npx tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:ai:setup": "npx tsx e2e/ai-setup.ts",
    "test:ai": "RUN_AI_TESTS=1 npx playwright test ai-provider-test.spec.ts",
    "demo": "tsx e2e/demo-video.ts",
    "demo:gifs": "tsx e2e/demo-gifs.ts",
    "lint:i18n": "npx tsx scripts/check-translations.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@hono/node-server": ">=1.19.13",
    "postcss": ">=8.5.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@rynfar/meridian": "^1.29.1",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.13.0",
    "@trpc/next": "^11.13.0",
    "@trpc/react-query": "^11.13.0",
    "@trpc/server": "^11.13.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "embedded-postgres": "^18.3.0-beta.16",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
