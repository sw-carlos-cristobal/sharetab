# Database
DATABASE_URL="postgresql://sharetab:sharetab@localhost:5432/sharetab"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_TRUST_HOST=true

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Provider: "openai" | "claude" | "claude-sdk" | "ollama"
# claude-sdk: uses Claude Agent SDK with your Max/Pro subscription (no API key needed, run `claude login` first)
AI_PROVIDER="openai"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ANTHROPIC_AUTH_TOKEN=""
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llava"

# Magic link email (optional — enables passwordless sign-in)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# File uploads
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB="10"

# Logging: "debug" | "info" | "warn" | "error" (default: "info" in production, "debug" in dev)
LOG_LEVEL="info"
