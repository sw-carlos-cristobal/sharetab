# ─── Database ───────────────────────────────────────────────
# For local dev with embedded-postgres (npm run dev:full):
DATABASE_URL="postgresql://postgres:postgres@localhost:51214/sharetab"
# For Docker (constructed from DB_USER/DB_PASSWORD/DB_NAME if not set):
# DATABASE_URL="postgresql://sharetab:sharetab@localhost:5432/sharetab"
DB_USER="sharetab"
DB_PASSWORD="sharetab"
DB_NAME="sharetab"

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_TRUST_HOST=true

# ─── OAuth (optional — enables Google sign-in) ─────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── AI Receipt Scanning ───────────────────────────────────
# Provider: "openai" | "claude" | "meridian" | "ollama" | "ocr"
# - openai: requires OPENAI_API_KEY (uses GPT-4o by default)
# - claude: requires ANTHROPIC_API_KEY
# - meridian: uses Claude Max subscription via embedded proxy (no API key, mount ~/.claude/.credentials.json)
# - ollama: local model, requires OLLAMA_BASE_URL
# - ocr: local Tesseract.js extraction, no API key needed (also used as automatic fallback)
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY=""
# Default model per provider: claude → claude-sonnet-4-6, meridian → claude-opus-4-6
# This env var overrides the default for both providers.
ANTHROPIC_MODEL="claude-sonnet-4-6"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llava"
# Port for the embedded Meridian proxy (only used with AI_PROVIDER=meridian)
MERIDIAN_PORT="3457"

# ─── Magic Link Email (optional — enables passwordless sign-in) ─
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# ─── File Uploads ───────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB="10"

# ─── Rate Limiting ──────────────────────────────────────────
# Max login/register attempts per IP per hour (increase for testing/CI)
AUTH_RATE_LIMIT_MAX="5"
REGISTER_RATE_LIMIT_MAX="10"

# ─── Admin ──────────────────────────────────────────────────
# Email of the admin user (grants access to /admin dashboard)
ADMIN_EMAIL=""

# ─── Logging ────────────────────────────────────────────────
# "debug" | "info" | "warn" | "error" (default: "info" in production, "debug" in dev)
LOG_LEVEL="info"
